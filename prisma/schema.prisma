generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  account  Account?

  @@map("users")
}

model Account {
  id     Int    @id @default(autoincrement())
  cardNo BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int    @unique

  @@map("accounts")
}
